{
  "agents": {
    "overrides": {
      "browser_agent": {
        "enabled": true
      }
    },
    "browser": {
      "sessionMode": "isolated",
      "headless": false,
      "allowedDomains": ["localhost"],
      "blockFileUploads": true,
      "confirmSensitiveActions": false
    }
  },
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "run_shell_command",
        "hooks": [
          {
            "name": "destructive-ops",
            "type": "command",
            "command": "$GEMINI_PROJECT_DIR/.gemini/hooks/block-destructive-ops.sh",
            "description": "Block destructive shell ops (force-push, hard reset, rm -rf, chmod 777, pipe-to-shell)"
          }
        ]
      }
    ]
  }
}
