{
  "agents": {
    "overrides": {
      "browser_agent": {
        "enabled": true
      }
    },
    "browser": {
      "sessionMode": "isolated",
      "headless": false,
      "allowedDomains": ["localhost"],
      "blockFileUploads": true,
      "confirmSensitiveActions": false
    }
  },
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "write_file|replace",
        "hooks": [
          {
            "name": "protected-paths",
            "type": "command",
            "command": "$GEMINI_PROJECT_DIR/.gemini/hooks/block-protected-paths.sh",
            "description": "Block writes to security-critical paths (.gemini/, .env, .git/, etc.)"
          },
          {
            "name": "mortgage-rules",
            "type": "command",
            "command": "$GEMINI_PROJECT_DIR/.gemini/hooks/enforce-mortgage-rules.sh",
            "description": "Enforce eu-mortgage-rules thresholds on lib/calculations.ts"
          }
        ]
      }
    ]
  }
}
